/*
============================================================
MINISUMO – DETECCIÓN INSTANTÁNEA + MODO BÚSQUEDA ACTIVA
============================================================
*/

#include <Adafruit_NeoPixel.h>

#define PUSH 12
#define LED  5

#define MOTOR_RIGHT_PWM 17
#define MOTOR_RIGHT_DIR 16
#define MOTOR_LEFT_DIR  18
#define MOTOR_LEFT_PWM   4

#define IR_FRONT_RIGHT 35
#define IR_FRONT_LEFT  39
#define IR_BACK_RIGHT  36
#define IR_BACK_LEFT   27

#define SENSOR_IZQ_EXTREMA 26
#define SENSOR_IZQ_CENTRO  25
#define SENSOR_CENTRO      33
#define SENSOR_DER_CENTRO  32
#define SENSOR_DER_EXTREMA 23

#define FREQUENCY_PWM   4000
#define RESOLUTION_PWM    10

#define UMBRAL_LINEA    3400
#define UMBRAL_ENEMIGO   300

#define VEL_MAXIMA       1023
#define VEL_CURVA_RAPIDA  500
#define VEL_CURVA_LENTA   150
#define VEL_BUSQUEDA_GIRO 400  // Velocidad durante barrido de búsqueda

#define TIEMPO_REVERSA_EVASION 300
#define TIEMPO_GIRO_EVASION    200

// ── MODO BÚSQUEDA: duraciones de cada fase (ms) ──────────
#define BUSQ_AVANCE_MS   350   // Avanza recto hacia el centro
#define BUSQ_GIRO_MS     300   // Giro de barrido lateral
#define BUSQ_ARCO_MS     500   // Arco amplio (espiral suave)

// Fases del modo búsqueda
enum FaseBusqueda { FASE_AVANCE, FASE_GIRO, FASE_ARCO };

Adafruit_NeoPixel pixels(1, LED, NEO_GRB + NEO_KHZ800);

int            ultimaDireccion        = 0;
uint32_t       colorActual            = 0;
int            velocidadActualIzq     = 9999;
int            velocidadActualDer     = 9999;

// Estado del modo búsqueda
FaseBusqueda   faseBusqueda           = FASE_AVANCE;
unsigned long  tiempoInicioFase       = 0;

// ── SETUP ────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  ledcAttach(MOTOR_RIGHT_PWM, FREQUENCY_PWM, RESOLUTION_PWM);
  ledcAttach(MOTOR_LEFT_PWM,  FREQUENCY_PWM, RESOLUTION_PWM);
  pinMode(MOTOR_RIGHT_DIR, OUTPUT);
  pinMode(MOTOR_LEFT_DIR,  OUTPUT);
  pinMode(PUSH, INPUT_PULLUP);
  pixels.begin();
  setLED(0, 150, 0);
  while(digitalRead(PUSH));
  for(int i = 0; i < 5; i++){
    setLED(150, 150, 0); delay(500);
    setLED(0, 0, 0);     delay(500);
  }
  tiempoInicioFase = millis();
}

// ── LOOP PRINCIPAL ───────────────────────────────────────
void loop(){
  if(!controlLinea()){
    estrategiaCombate();
  }
}

// ─────────────────────────────────────────────────────────
//  ESTRATEGIA DE COMBATE + MODO BÚSQUEDA INTEGRADO
// ─────────────────────────────────────────────────────────
void estrategiaCombate(){
  bool eIzqExt = analogRead(SENSOR_IZQ_EXTREMA) > UMBRAL_ENEMIGO;
  bool eIzqCen = analogRead(SENSOR_IZQ_CENTRO)  > UMBRAL_ENEMIGO;
  bool eCentro = analogRead(SENSOR_CENTRO)       > UMBRAL_ENEMIGO;
  bool eDerCen = analogRead(SENSOR_DER_CENTRO)   > UMBRAL_ENEMIGO;
  bool eDerExt = analogRead(SENSOR_DER_EXTREMA)  > UMBRAL_ENEMIGO;

  bool hayEnemigo = eIzqExt || eIzqCen || eCentro || eDerCen || eDerExt;

  // Si detecta enemigo: resetea el ciclo de búsqueda para
  // que cuando lo pierda vuelva a empezar desde FASE_AVANCE
  if(hayEnemigo){
    faseBusqueda     = FASE_AVANCE;
    tiempoInicioFase = millis();
  }

  if(eCentro){
    setLED(0, 0, 255);
    setMotors(VEL_MAXIMA, VEL_MAXIMA);
  }
  else if(eIzqCen){
    ultimaDireccion = 0;
    setLED(0, 150, 255);
    setMotors(VEL_CURVA_RAPIDA, VEL_MAXIMA);
  }
  else if(eDerCen){
    ultimaDireccion = 1;
    setLED(0, 150, 255);
    setMotors(VEL_MAXIMA, VEL_CURVA_RAPIDA);
  }
  else if(eIzqExt){
    ultimaDireccion = 0;
    setLED(100, 0, 255);
    setMotors(VEL_CURVA_LENTA, VEL_MAXIMA);
  }
  else if(eDerExt){
    ultimaDireccion = 1;
    setLED(100, 0, 255);
    setMotors(VEL_MAXIMA, VEL_CURVA_LENTA);
  }
  else{
    // ── MODO BÚSQUEDA ACTIVA ─────────────────────────────
    modoBusqueda();
  }
}

// ─────────────────────────────────────────────────────────
//  MODO BÚSQUEDA: 3 fases en ciclo, sin delay()
//  Avance recto → Giro barrido → Arco espiral → repite
//
//  La lógica es no-bloqueante: usa millis() para avanzar
//  de fase, así controlLinea() se sigue ejecutando cada
//  iteración del loop aunque estemos en modo búsqueda.
// ─────────────────────────────────────────────────────────
void modoBusqueda(){
  unsigned long ahora    = millis();
  unsigned long transcurrido = ahora - tiempoInicioFase;

  switch(faseBusqueda){

    case FASE_AVANCE:
      // Avanza directo hacia el centro del dohyo
      setLED(255, 140, 0);
      setMotors(VEL_MAXIMA, VEL_MAXIMA);
      if(transcurrido >= BUSQ_AVANCE_MS){
        faseBusqueda     = FASE_GIRO;
        tiempoInicioFase = ahora;
      }
      break;

    case FASE_GIRO:
      // Barrido lateral: gira hacia el lado donde vio al
      // enemigo por última vez para cubrir ese sector
      setLED(255, 80, 0);
      if(ultimaDireccion == 0){
        setMotors(-VEL_BUSQUEDA_GIRO, VEL_BUSQUEDA_GIRO); // giro izquierda
      } else {
        setMotors(VEL_BUSQUEDA_GIRO, -VEL_BUSQUEDA_GIRO); // giro derecha
      }
      if(transcurrido >= BUSQ_GIRO_MS){
        // Alterna la dirección del barrido en el siguiente ciclo
        ultimaDireccion  = 1 - ultimaDireccion;
        faseBusqueda     = FASE_ARCO;
        tiempoInicioFase = ahora;
      }
      break;

    case FASE_ARCO:
      // Arco amplio hacia adelante: una llanta más rápida
      // crea una trayectoria curva que barre el área
      setLED(200, 50, 0);
      if(ultimaDireccion == 0){
        setMotors(VEL_CURVA_LENTA, VEL_MAXIMA);  // arco hacia izquierda
      } else {
        setMotors(VEL_MAXIMA, VEL_CURVA_LENTA);  // arco hacia derecha
      }
      if(transcurrido >= BUSQ_ARCO_MS){
        faseBusqueda     = FASE_AVANCE;
        tiempoInicioFase = ahora;
      }
      break;
  }
}

// ─────────────────────────────────────────────────────────
//  CONTROL DE LÍNEA — reacción instantánea sin promedios
// ─────────────────────────────────────────────────────────
bool controlLinea(){
  bool lineaFR = analogRead(IR_FRONT_RIGHT) < UMBRAL_LINEA;
  bool lineaFL = analogRead(IR_FRONT_LEFT)  < UMBRAL_LINEA;
  bool lineaBR = analogRead(IR_BACK_RIGHT)  < UMBRAL_LINEA;
  bool lineaBL = analogRead(IR_BACK_LEFT)   < UMBRAL_LINEA;

  if(lineaFR || lineaFL){
    setLED(255, 0, 0);
    setMotors(-VEL_MAXIMA, -VEL_MAXIMA);
    delay(TIEMPO_REVERSA_EVASION);

    if(lineaFR && !lineaFL){
      setMotors(-VEL_MAXIMA, VEL_MAXIMA);
      ultimaDireccion = 0;
    } else if(lineaFL && !lineaFR){
      setMotors(VEL_MAXIMA, -VEL_MAXIMA);
      ultimaDireccion = 1;
    } else {
      (ultimaDireccion == 0)
        ? setMotors(-VEL_MAXIMA, VEL_MAXIMA)
        : setMotors(VEL_MAXIMA, -VEL_MAXIMA);
    }
    delay(TIEMPO_GIRO_EVASION);

    // Resetea búsqueda para empezar con avance al salir
    faseBusqueda     = FASE_AVANCE;
    tiempoInicioFase = millis();
    return true;
  }

  if(lineaBR || lineaBL){
    setLED(255, 120, 0);
    setMotors(VEL_MAXIMA, VEL_MAXIMA);
    delay(TIEMPO_REVERSA_EVASION);

    if(lineaBR && !lineaBL){
      setMotors(VEL_MAXIMA, -VEL_MAXIMA);
      ultimaDireccion = 1;
    } else if(lineaBL && !lineaBR){
      setMotors(-VEL_MAXIMA, VEL_MAXIMA);
      ultimaDireccion = 0;
    } else {
      (ultimaDireccion == 0)
        ? setMotors(VEL_MAXIMA, -VEL_MAXIMA)
        : setMotors(-VEL_MAXIMA, VEL_MAXIMA);
    }
    delay(TIEMPO_GIRO_EVASION);

    faseBusqueda     = FASE_AVANCE;
    tiempoInicioFase = millis();
    return true;
  }

  return false;
}

// ─────────────────────────────────────────────────────────
//  MOTORES Y LED
// ─────────────────────────────────────────────────────────
void setMotors(int vL, int vR){
  if(vR != velocidadActualDer){
    setMotor(MOTOR_RIGHT_DIR, MOTOR_RIGHT_PWM, -vR);
    velocidadActualDer = vR;
  }
  if(vL != velocidadActualIzq){
    setMotor(MOTOR_LEFT_DIR, MOTOR_LEFT_PWM, -vL);
    velocidadActualIzq = vL;
  }
}

void setMotor(int dir, int pwm, int vel){
  vel = constrain(vel, -1023, 1023);
  if(vel > 0){
    ledcWrite(pwm, vel);
    digitalWrite(dir, 1);
  } else if(vel < 0){
    ledcWrite(pwm, -vel);
    digitalWrite(dir, 0);
  } else {
    ledcWrite(pwm, 0);
  }
}

void setLED(uint8_t r, uint8_t g, uint8_t b){
  uint32_t nuevoColor = pixels.Color(r, g, b);
  if(colorActual != nuevoColor){
    pixels.setPixelColor(0, nuevoColor);
    pixels.show();
    colorActual = nuevoColor;
  }
}
